template do {
	with content:block while:literal execute:literal execute_condition:raw {
		{
			# do {
			<%%
				content.node.body.forEach(node => emit.mcb(node))
			%%>
			# } while execute <%execute_condition%> {
			execute <%execute_condition%> function <%context.functions.at(-1)%>
			# }
		}
	}

	with content:block while:literal interval:word execute:literal execute_condition:raw {
		{
			# do {
			<%%
				content.node.body.forEach(node => emit.mcb(node))
			%%>
			# } while <%interval%> execute <%execute_condition%> {
			execute <%execute_condition%> schedule function <%context.functions.at(-1)%> <%interval%>
			# }
		}
	}

	with content:block until:literal execute:literal execute_condition:raw {
		{
			# do {
			<%%
				content.node.body.forEach(node => emit.mcb(node))
			%%>
			# } until execute <%execute_condition%> {
			scoreboard players set #check <%config.internalScoreboardName%> 0
			execute store result score #check <%config.internalScoreboardName%> <%execute_condition.replace(/ run$/, '')%>
			execute if score #check <%config.internalScoreboardName%> matches 0 run function <%context.functions.at(-1)%>
			# }
		}
	}

	with content:block until:literal interval:word execute:literal execute_condition:raw {
		{
			# do {
			<%%
				content.node.body.forEach(node => emit.mcb(node))
			%%>
			# } until <%interval%> execute <%execute_condition%> {
			scoreboard players set #check <%config.internalScoreboardName%> 0
			execute store result score #check <%config.internalScoreboardName%> <%execute_condition.replace(/ run$/, '')%>
			execute if score #check <%config.internalScoreboardName%> matches 0 run schedule function <%context.functions.at(-1)%> <%interval%>
			# }
		}
	}
}

