import ./sequence.mcbt

function load minecraft:load {
	sequence {
		say loading

		sleep 5t

		say hi
		playsound minecraft:entity.player.levelup master @a

		sleep 2s

		say bye
		playsound minecraft:block.note_block.bell master @a

		sleep 1t until execute if entity @a[tag=test]

		say you have the test tag!

		sleep 1t while execute if entity @a[tag=test]

		say you lost the test tag!
	}
}